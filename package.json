{
  "name": "@vetaucaotoc/frontend",
  "version": "3.2.7",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:turbo": "next dev --turbo -p 3001",
    "build": "next build",
    "build:uat": "env-cmd -f .env.uat npm run build",
    "postbuild": "cross-env next-sitemap && cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/",
    "postbuild:uat": "cp .env.uat .next/standalone/.env",
    "build:analyze": "cross-env ANALYZE=true npm run build",
    "build:cypress": "cross-env cp example.env.local .env.local && next build",
    "start": "node .next/standalone/server.js",
    "start:dev": "cross-env PORT=3001 npm run start",
    "lint": "next lint",
    "format": "prettier --write src/ --ignore-unknown",
    "prepare": "is-ci || husky",
    "ts": "tsc --noEmit --incremental",
    "ts:watch": "npm run ts --watch"
  },
